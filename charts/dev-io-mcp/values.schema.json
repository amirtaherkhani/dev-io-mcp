{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "replicaCount": {
      "type": "integer",
      "minimum": 1
    },
    "image": {
      "type": "object",
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] },
        "tag": { "type": "string" },
        "digest": { "type": "string" }
      },
      "required": ["repository", "pullPolicy", "tag", "digest"]
    },
    "transport": {
      "type": "object",
      "properties": {
        "mode": { "type": "string", "enum": ["http"] },
        "host": { "type": "string", "minLength": 1 },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 }
      },
      "required": ["mode", "host", "port"]
    },
    "service": {
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["ClusterIP", "NodePort", "LoadBalancer"] },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 }
      },
      "required": ["type", "port"]
    },
    "remote": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "apiBaseUrl": { "type": "string" },
        "existingSecret": { "type": "string" },
        "existingSecretKey": { "type": "string", "minLength": 1 },
        "createSecret": { "type": "boolean" },
        "apiToken": { "type": "string" }
      },
      "required": ["enabled", "apiBaseUrl", "existingSecret", "existingSecretKey", "createSecret", "apiToken"]
    },
    "persistence": {
      "type": "object",
      "properties": {
        "posts": { "$ref": "#/$defs/persistenceVolume" },
        "data": { "$ref": "#/$defs/persistenceVolume" }
      },
      "required": ["posts", "data"]
    },
    "autoscaling": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "minReplicas": { "type": "integer", "minimum": 1 },
        "maxReplicas": { "type": "integer", "minimum": 1 },
        "targetCPUUtilizationPercentage": { "type": "integer", "minimum": 1, "maximum": 100 },
        "targetMemoryUtilizationPercentage": { "type": ["integer", "string"] }
      },
      "required": ["enabled", "minReplicas", "maxReplicas", "targetCPUUtilizationPercentage", "targetMemoryUtilizationPercentage"]
    }
  },
  "$defs": {
    "persistenceVolume": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "mountPath": { "type": "string", "minLength": 1 },
        "accessModes": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "size": { "type": "string", "minLength": 1 },
        "storageClass": { "type": "string" },
        "annotations": { "type": "object" }
      },
      "required": ["enabled", "mountPath", "accessModes", "size", "storageClass", "annotations"]
    }
  }
}
