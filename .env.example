# Optional remote metrics adapter. Leave unset for local-only metrics.
DEV_IO_API_BASE_URL=https://your-dev-io-domain.example
DEV_IO_API_TOKEN=

# Optional official DEV.to/Forem publishing adapter.
# Set DEV_TO_PUBLISH=true only when you want publish_post to create a remote article.
DEV_TO_PUBLISH=false
DEV_TO_API_BASE_URL=https://dev.to
DEV_TO_API_KEY=
DEV_TO_PUBLISHED=true
DEV_TO_USER_AGENT=dev-io-mcp/0.1.0 (https://github.com/amirtaherkhani/dev-io-mcp)
