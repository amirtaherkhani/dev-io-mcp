{
  "name": "dev-io-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "MCP server for turning AI conversations into dev.io markdown posts.",
  "bin": {
    "dev-io-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod 755 dist/index.js",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "inspect": "npx -y @modelcontextprotocol/inspector node dist/index.js",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.2.0",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2"
  }
}
