{
  "name": "dev-io-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "MCP server for turning AI conversations into dev.io markdown posts.",
  "bin": {
    "dev-io-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod 755 dist/index.js",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "start:http": "MCP_TRANSPORT=http MCP_HOST=0.0.0.0 node dist/index.js",
    "inspect": "npx -y @modelcontextprotocol/inspector node dist/index.js",
    "docker:build": "docker build -t dev-io-mcp:local .",
    "docker:run": "docker run --rm -p 3000:3000 -v \"$(pwd)/posts:/app/posts\" -v \"$(pwd)/data:/app/data\" dev-io-mcp:local",
    "k8s:render": "kubectl kustomize deploy/k8s/overlays/local",
    "k8s:apply": "kubectl apply -k deploy/k8s/overlays/local",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.2.0",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2"
  }
}
