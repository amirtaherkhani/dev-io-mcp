{
  "name": "dev-io-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "MCP server for turning AI conversations into dev.io markdown posts.",
  "bin": {
    "dev-io-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod 755 dist/index.js",
    "helm:lint": "helm lint charts/dev-io-mcp",
    "helm:template": "helm template dev-io-mcp charts/dev-io-mcp --namespace dev-io",
    "lint": "tsc -p tsconfig.json --noEmit",
    "install:codex": "bash scripts/install-codex.sh",
    "install:claude": "bash scripts/install-claude.sh"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.2.0",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2"
  }
}
